<%- include('../partials/header') %>
<%- include('../partials/app-shell-start') %>

<section class="card">
  <h2>Gestión de usuarios</h2>
  <p>Solo administradores pueden crear cuentas y definir si son operador o administrador.</p>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert success"><%= success %></div>
  <% } %>

  <form method="POST" action="/usuarios" class="form-inline">
    <input type="text" name="username" placeholder="Nombre de usuario" required />
    <input type="password" name="password" placeholder="Contraseña" required />
    <select name="role" required>
      <option value="">Rol</option>
      <option value="operador">Operador</option>
      <option value="admin">Administrador</option>
    </select>
    <button class="btn btn-primary" type="submit">Crear usuario</button>
  </form>

  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Usuario</th>
        <th>Rol</th>
        <th>Creado</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach((row) => { %>
        <tr>
          <td><%= row.id %></td>
          <td><%= row.username %></td>
          <td><span class="badge"><%= row.role %></span></td>
          <td><%= row.created_at %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('../partials/app-shell-end') %>
<%- include('../partials/footer') %>
