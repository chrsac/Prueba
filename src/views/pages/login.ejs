<%- include('../partials/header') %>

<div class="login-wrapper">
  <div class="login-card">
    <h1>Plataforma de Arquitectura Node.js</h1>
    <p>Accede para administrar usuarios y configuración del sistema.</p>

    <% if (error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <form method="POST" action="/login" class="form-grid">
      <label>
        Usuario
        <input name="username" type="text" placeholder="Ingresa tu usuario" required />
      </label>

      <label>
        Contraseña
        <input name="password" type="password" placeholder="Ingresa tu contraseña" required />
      </label>

      <button class="btn btn-primary" type="submit">Iniciar sesión</button>
    </form>

    <small>Usuario inicial: <b>admin</b> / <b>admin123</b></small>
  </div>
</div>

<%- include('../partials/footer') %>
