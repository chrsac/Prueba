<div class="app-layout">
  <aside class="sidebar">
    <div class="brand">Arquitectura Node.js</div>
    <nav>
      <% menuItems.forEach((item) => { %>
        <a href="<%= item.path %>" class="menu-link <%= activeMenu === item.key ? 'active' : '' %>">
          <span><%= item.icon %></span>
          <span><%= item.label %></span>
        </a>
      <% }) %>
    </nav>
  </aside>

  <div class="content-area">
    <header class="topbar">
      <div class="topbar-title"><%= title %></div>
      <div class="topbar-actions">
        <button class="btn btn-secondary" type="button">Preferencias</button>
        <div class="user-pill"><%= currentUser.username %> · <%= currentUser.role %></div>
        <form action="/logout" method="POST">
          <button class="btn btn-danger" type="submit">Cerrar sesión</button>
        </form>
      </div>
    </header>
    <main class="main-content">
